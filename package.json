{
  "name": "pptx-parser-for-ai",
  "version": "0.1.0",
  "description": "Secure and deterministic PPTX generator from declarative DSL",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "themes"
  ],
  "scripts": {
    "clean": "rm -rf dist coverage .tmp",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" \"example/**/*.ts\"",
    "test": "npm run test:unit && npm run test:integration && npm run test:security && npm run example:test",
    "test:unit": "vitest run tests/unit --reporter=dot --pool=forks --poolOptions.forks.singleFork",
    "test:integration": "vitest run tests/integration --reporter=dot --pool=forks --poolOptions.forks.singleFork",
    "test:security": "vitest run tests/security --reporter=dot --pool=forks --poolOptions.forks.singleFork && npm run security:audit",
    "test:coverage": "vitest run tests/unit tests/integration tests/security --coverage --pool=forks --poolOptions.forks.singleFork",
    "test:perf": "vitest run tests/performance --reporter=dot --pool=forks --poolOptions.forks.singleFork",
    "test:fuzz": "vitest run tests/fuzz --reporter=dot --pool=forks --poolOptions.forks.singleFork",
    "security:audit": "npm audit --omit=dev --audit-level=high",
    "security:all": "npm run test:security && npm run security:audit",
    "example:test": "tsx example/run-example-tests.ts",
    "quality:check": "npm run lint && npm run typecheck && npm run test:coverage && npm run test:integration && npm run test:security && npm run test:perf && npm run test:fuzz && npm run example:test && npm run build",
    "prepublishOnly": "npm run quality:check"
  },
  "keywords": [
    "pptx",
    "dsl",
    "typescript"
  ],
  "author": "ymuichiro",
  "license": "MIT",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ymuichiro/pptx-parser-for-ai.git"
  },
  "homepage": "https://github.com/ymuichiro/pptx-parser-for-ai#readme",
  "bugs": {
    "url": "https://github.com/ymuichiro/pptx-parser-for-ai/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "fast-xml-parser": "^5.4.1",
    "js-yaml": "^4.1.0",
    "jszip": "^3.10.1",
    "pptxgenjs": "^3.12.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.4",
    "@typescript-eslint/eslint-plugin": "^8.24.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.20.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
